<header class="py-5 border-bottom bg-light mx-n3 mt-n4 mb-4">
  <div class="container px-5">
    <div class="row gx-5 justify-content-center">
      <div class="col-lg-8">
        <div class="text-center my-5">
          <h1 class="display-5 fw-bolder text-dark mb-2">Connect with your University Community</h1>
          <p class="lead text-muted mb-4">Discover, organize, and join the best workshops, sports activities, and study groups on campus.</p>
          <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
            <%= link_to "Browse Events", events_path, class: "btn btn-primary btn-lg px-4 me-sm-3" %>
            <a class="btn btn-outline-dark btn-lg px-4" href="#about">Learn More</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<section class="py-5" id="about">
  <div class="container px-5 my-5">
    <div class="row gx-5">
      <div class="col-lg-4 mb-5 mb-lg-0">
        <h2 class="fw-bolder mb-0">What is EventHub?</h2>
      </div>
      <div class="col-lg-8">
        <p class="lead fw-normal text-muted mb-4">EventHub is a centralized platform designed for students and faculty members. Whether you want to lead a coding workshop, organize a soccer match, or find a study group for finals, we provide the tools to make it happen.</p>
        <p class="text-muted">Our smart registration system handles capacity limits and waiting lists automatically, so you can focus on the event itself. After attending, share your experience with reviews to help our community grow.</p>
      </div>
    </div>
  </div>
</section>

<section class="py-5 bg-light mx-n3">
  <div class="container px-5 my-5">
    <div class="text-center">
      <h2 class="fw-bolder">Get in Touch</h2>
      <p class="lead fw-normal text-muted mb-5">Have questions or need support with your event?</p>
    </div>
    <div class="row gx-5 justify-content-center">
      <div class="col-lg-6">
        <div class="card p-4 text-center">
          <div class="card-body">
            <p class="mb-0"><strong>Email:</strong> support@eventhub.uandes.cl</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
