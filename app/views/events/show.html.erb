<div class="row">
  <div class="col-lg-8">
    <h1 class="fw-bolder mb-1"><%= @event.title %></h1>
    <div class="text-muted fst-italic mb-2">Organized by <%= @event.organizer.full_name %></div>
    
    <%= link_to @event.category.name, category_path(@event.category), class: "badge bg-secondary text-decoration-none link-light mb-4" %>
    <span class="badge bg-info text-decoration-none link-light mb-4"><%= @event.state.capitalize %></span>

    <section class="mb-5 mt-4">
      <!-- Muestra el ActionText -->
      <%= @event.description %>
    </section>
  </div>
  
  <div class="col-lg-4">
    <div class="card mb-4 shadow-sm">
      <div class="card-header bg-primary text-white">Event Details</div>
      <div class="card-body">
        <p><strong>Venue:</strong> <%= link_to @event.venue.name, venue_path(@event.venue) %></p>
        <p><strong>Start Date:</strong> <%= @event.start_date.strftime("%d/%m/%Y %H:%M") %></p>
        <p><strong>End Date:</strong> <%= @event.end_date.strftime("%d/%m/%Y %H:%M") %></p>
        <p><strong>Capacity:</strong> <%= @event.max_capacity %> people</p>
      </div>
    </div>
    <%= link_to 'Back to Events', events_path, class: 'btn btn-secondary w-100' %>
  </div>
</div>
