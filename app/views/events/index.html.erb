<h1 class="mb-4">All Events</h1>
<div class="row">
  <% @events.each do |event| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body">
          <h5 class="card-title"><%= event.title %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= event.category.name %> | <%= event.venue.name %></h6>
          <p class="card-text"><strong>Starts:</strong> <%= event.start_date.strftime("%d/%m/%Y %H:%M") %></p>
          <span class="badge bg-info mb-3"><%= event.state.capitalize %></span>
          <br>
          <%= link_to 'View Details', event_path(event), class: 'btn btn-outline-primary' %>
        </div>
      </div>
    </div>
  <% end %>
</div>
