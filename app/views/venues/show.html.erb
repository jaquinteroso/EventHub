<div class="card mb-4 shadow-sm">
  <div class="card-body">
    <h2 class="card-title"><%= @venue.name %></h2>
    <h6 class="card-subtitle mb-2 text-muted"><%= @venue.address %></h6>
    <p class="card-text mt-3"><strong>Maximum Capacity:</strong> <%= @venue.capacity_max %> people</p>
  </div>
</div>

<h4 class="mb-3">Events at this Venue</h4>
<ul class="list-group mb-4">
  <% @events.each do |event| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <%= link_to event.title, event_path(event), class: "text-decoration-none" %>
      <span class="badge bg-primary rounded-pill"><%= event.start_date.strftime("%d/%m") %></span>
    </li>
  <% end %>
</ul>

<%= link_to 'Back to Venues', venues_path, class: "btn btn-secondary" %>
